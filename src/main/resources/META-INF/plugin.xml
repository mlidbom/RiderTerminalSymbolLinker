<idea-plugin>
    <id>dev.magnus.riderterminalsymbollinker</id>
    <name>.NET Terminal Symbol Linker</name>
    <vendor email="magnus.lidbom@gmail.com" url="https://github.com/mlidbom/RiderTerminalSymbolLinker">Magnus Lidbom</vendor>
    <description><![CDATA[
        Makes .NET symbol names and full or partial file paths in Rider's terminal output clickable — a
        click jumps to the symbol's declaration, or opens the file. Helpful for working with
        <a href="https://www.anthropic.com/claude-code">Claude Code</a> and other agents that run in
        the terminal.
        <br/><br/>
        <b>Requires</b> the ReSharper MCP plugin (<code>com.j-light.resharper-mcp</code>) running in
        Rider.
    ]]></description>

    <!-- Gates the plugin to Rider only: this module provides the ReSharper backend the plugin relies on.
         Without it the Marketplace would offer the plugin to every IntelliJ-based IDE, where it can't work. -->
    <depends>com.intellij.modules.rider</depends>
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>
    <!-- Needed so the Terminal.ReworkedTerminalContextMenu group exists when our action registers. -->
    <depends>org.jetbrains.plugins.terminal</depends>
    <!-- The ReSharper MCP that resolves and enumerates C# symbols. Hard dependency: without it this
         plugin can't function, so the Marketplace prompts users to install it alongside this one. -->
    <depends>com.j-light.resharper-mcp</depends>

    <extensions defaultExtensionNs="com.intellij">
        <consoleFilterProvider implementation="dev.magnus.csl.SymbolLinkFilterProvider"/>
        <notificationGroup id="RiderTerminalSymbolLinker" displayType="BALLOON"/>
        <!-- Sticky so the first-run "symbols are loading" notice stays visible until the build finishes,
             instead of fading like the status-bar progress. It is expired programmatically when done. -->
        <notificationGroup id="RiderTerminalSymbolLinker.Startup" displayType="STICKY_BALLOON"/>
        <postStartupActivity implementation="dev.magnus.csl.SymbolIndexStartup"/>
        <postStartupActivity implementation="dev.magnus.csl.SolutionFileIndexStartup"/>
    </extensions>

    <actions>
        <action id="RiderTerminalSymbolLinker.RefreshSymbols"
                class="dev.magnus.csl.RefreshSymbolsAction"
                text="Refresh Terminal Links"
                description="Reload the C# symbol and solution-file indexes so newly added or renamed symbols and files become clickable in later terminal output.">
            <add-to-group group-id="Terminal.ReworkedTerminalContextMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
